<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}Project Portfolio</title>
    <link rel="icon" href="{{ '/favicon.svg' | url }}" type="image/svg+xml" />
    <link rel="stylesheet" href="{{ '/styles.css' | url }}" />
  </head>
  <body>
    <header class="site-header">
      <div class="brand">
        <svg id="header-robot" class="robot robot-boopable" viewBox="0 0 64 68" role="img" aria-label="Robot mascot — click to boop">
          <!-- antenna -->
          <line class="antenna-stem" x1="32" y1="4" x2="32" y2="14" />
          <circle class="antenna" cx="32" cy="5" r="3.4" />
          <!-- head -->
          <rect class="head" x="10" y="14" width="44" height="36" rx="12" />
          <!-- ears / bolts -->
          <rect class="bolt" x="5" y="26" width="5" height="12" rx="2.5" />
          <rect class="bolt" x="54" y="26" width="5" height="12" rx="2.5" />
          <!-- eyes -->
          <g class="eyes">
            <circle class="eye" cx="24" cy="30" r="4.2" />
            <circle class="eye" cx="40" cy="30" r="4.2" />
          </g>
          <!-- mouth grille -->
          <rect class="mouth" x="21" y="40" width="22" height="5" rx="2.5" />
          <!-- neck + body hint -->
          <rect class="neck" x="28" y="50" width="8" height="5" rx="2" />
          <rect class="body" x="16" y="55" width="32" height="10" rx="5" />
        </svg>
        <div class="brand-text">
          <a class="site-title" href="{{ '/' | url }}">Marco Lara<span class="title-dot">.</span></a>
          <p class="site-tagline">Projects &amp; things I've built</p>
        </div>
      </div>
    </header>

    <main>{{ content | safe }}</main>

    <footer class="site-footer">
      <p>Built with Eleventy · <a href="https://github.com/m-lara95/portfolio" rel="noopener">source</a></p>
    </footer>

    <!-- Fixed chat-bubble launcher for the mini-game -->
    <button type="button" class="game-launch" id="game-open">🎁 click here for a surprise</button>

    <!-- Mini-game: BOT-MUNCHER -->
    <div class="game-overlay" id="game" hidden data-sprite="{{ '/robot-sprite.svg' | url }}">
      <div class="game-panel" role="dialog" aria-modal="true" aria-label="Mini-game: Boop the Bot">
        <div class="game-head">
          <span class="game-title">🤖 BOT-MUNCHER</span>
          <button type="button" class="game-close" id="game-close" aria-label="Close game">✕</button>
        </div>
        <div class="game-hud">
          <span>SCORE <b id="game-score">0</b></span>
          <span>LIVES <b id="game-lives">3</b></span>
          <span>BEST <b id="game-best">0</b></span>
        </div>
        <div class="game-area" id="game-area">
          <button type="button" class="game-start" id="game-start">PRESS START</button>
        </div>
        <p class="game-hint">Arrow keys / WASD — eat all the dots, dodge the bugs!</p>
      </div>
    </div>

    <!-- Peeking robot: hidden off-screen, pops up briefly on tab switch -->
    <div class="robot-popup" aria-hidden="true">
      <div class="robot-bubble"></div>
      <svg class="robot" viewBox="0 0 64 68">
        <line class="antenna-stem" x1="32" y1="4" x2="32" y2="14" />
        <circle class="antenna" cx="32" cy="5" r="3.4" />
        <rect class="head" x="10" y="14" width="44" height="36" rx="12" />
        <rect class="bolt" x="5" y="26" width="5" height="12" rx="2.5" />
        <rect class="bolt" x="54" y="26" width="5" height="12" rx="2.5" />
        <circle class="eye" cx="24" cy="30" r="4.2" />
        <circle class="eye" cx="40" cy="30" r="4.2" />
        <rect class="mouth" x="21" y="40" width="22" height="5" rx="2.5" />
        <rect class="neck" x="28" y="50" width="8" height="5" rx="2" />
        <rect class="body" x="16" y="55" width="32" height="10" rx="5" />
      </svg>
    </div>

    <script src="{{ '/js/tabs.js' | url }}" defer></script>
  </body>
</html>
